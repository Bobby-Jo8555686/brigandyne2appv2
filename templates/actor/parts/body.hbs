<section class="sheet-body">
    <div class="tab stats" data-tab="stats" style="display:block;">
        <div class="stats-container">
            <div class="competences-col">
                <div class="comp-header">
                    <div class="flex-2">Compétences</div>
                    <div class="stat-base" title="Base">Bs.</div>
                    <div class="stat-prog" title="Progression">Prog.</div>
                    <div class="stat-actual" title="Actuel">Act.</div>
                </div>
                <div class="item-list">
                    {{#each system.stats as |stat key|}}
                    <div class="stat-row">
                        <label class="stat-label cursor-pointer" data-action="rollStat" data-key="{{key}}">{{stat.label}}</label>
                        <div class="stat-base"><input type="number" name="system.stats.{{key}}.value" value="{{stat.value}}"/></div>
                        <div class="stat-prog flex-row justify-center gap-3 pt-4">
                            {{#each stat.progressBoxes}}
                            <a class="prog-box {{#if checked}}checked{{/if}} {{#if locked}}locked{{/if}}" data-action="progressClick" data-stat="{{statKey}}" data-value="{{value}}" title="{{#if locked}}Hors Profil{{else}}Niveau {{value}}{{/if}}"></a>
                            {{/each}}
                        </div>
                        <div class="stat-actual"><div class="actual-box">{{stat.total}}</div></div>
                    </div>
                    {{/each}}
                </div>

                <div class="handicaps-box">
                    <h3 class="handicaps-title"><i class="fas fa-skull-crossbones"></i> États & Handicaps</h3>
                    <div class="handicaps-grid">
                        <label class="handicap-label"><input type="checkbox" name="system.handicaps.affaibli" {{checked system.handicaps.affaibli}}/> Affaibli (-10)</label>
                        <label class="handicap-label"><input type="checkbox" name="system.handicaps.affame" {{checked system.handicaps.affame}}/> Affamé (-1 DG)</label>
                        <label class="handicap-label"><input type="checkbox" name="system.handicaps.apeure" {{checked system.handicaps.apeure}}/> Apeuré</label>
                        <label class="handicap-label"><input type="checkbox" name="system.handicaps.aveugle" {{checked system.handicaps.aveugle}}/> Aveuglé (0)</label>
                        <label class="handicap-label"><input type="checkbox" name="system.handicaps.confus" {{checked system.handicaps.confus}}/> Confus</label>
                        <label class="handicap-label"><input type="checkbox" name="system.handicaps.demoralise" {{checked system.handicaps.demoralise}}/> Démoralisé</label>
                        <label class="handicap-label"><input type="checkbox" name="system.handicaps.ensanglante" {{checked system.handicaps.ensanglante}}/> Ensanglanté</label>
                        <label class="handicap-label"><input type="checkbox" name="system.handicaps.essouffle" {{checked system.handicaps.essouffle}}/> Essoufflé</label>
                        <label class="handicap-label"><input type="checkbox" name="system.handicaps.paralyse" {{checked system.handicaps.paralyse}}/> Paralysé</label>
                        <label class="handicap-label"><input type="checkbox" name="system.handicaps.ralenti" {{checked system.handicaps.ralenti}}/> Ralenti</label>
                        <label class="handicap-label"><input type="checkbox" name="system.handicaps.sonne" {{checked system.handicaps.sonne}}/> Sonné</label>
                        <label class="handicap-label"><input type="checkbox" name="system.handicaps.terrorise" {{checked system.handicaps.terrorise}}/> Terrorisé</label>
                    </div>
                    <div class="text-center mt-10"><a class="ignore-handicap-btn" data-action="ignoreHandicap"><i class="fas fa-fire-alt"></i> Ignorer (2 SF)</a></div>
                </div>
            </div>

            <div class="right-col">
                <div class="item-section">
                    <div class="item-header">
                        <h3 class="item-title"><i class="fas fa-khanda"></i> Armes (Accès rapide)</h3>
                        <div class="item-controls"><a class="item-control" data-action="createItem" data-type="arme"><i class="fas fa-plus"></i></a></div>
                    </div>
                    <div class="item-list">
                        {{#each armes as |arme id|}}
                        <div class="item" data-item-id="{{arme._id}}">
                            <div class="item-entry">
                                <div class="item-name-col">
                                    <img class="item-image cursor-pointer" data-action="rollWeapon" src="{{arme.img}}" title="Attaquer"/>
                                    <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{arme.name}}</h4>
                                </div>
                                <div class="item-details-col">DG: {{arme.system.degats_fixe}}</div>
                                <div class="item-controls">
                                    <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                                    <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                                </div>
                            </div>
                            <div class="item-summary mt-5">
                                <div class="font-09 text-muted mb-5">Type: {{#if (eq arme.system.type_arme "melee")}}Mêlée{{else}}Distance{{/if}} | Prise: {{arme.system.mains}} main(s)</div>
                                {{#if arme.system.special}}<div class="color-gold mb-5"><strong>Spécial:</strong> {{arme.system.special}}</div>{{/if}}
                                {{{arme.system.description}}}
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </div>
                <div class="item-section">
                    <div class="item-header gold">
                        <h3 class="item-title"><i class="fas fa-star"></i> Spécialités & Talents</h3>
                        <div class="item-controls"><a class="item-control" data-action="createItem" data-type="atout"><i class="fas fa-plus"></i></a></div>
                    </div>
                    <div class="item-list">
                        {{#each atouts as |atout id|}}
                        <div class="item" data-item-id="{{atout._id}}">
                            <div class="item-entry">
                                <div class="item-name-col flex-col align-stretch">
                                    <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{atout.name}}</h4>
                                    <div class="text-muted mt-5">
                                        <strong>{{atout.system.type_atout}}</strong> {{#if atout.system.stat_liee}}({{atout.system.stat_liee}}){{/if}}
                                        {{#if atout.system.bonus}}<span class="text-highlight">+{{atout.system.bonus}}</span>{{/if}}
                                    </div>
                                </div>
                                <div class="item-controls">
                                    <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                                    <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                                </div>
                            </div>
                            <div class="item-summary mt-5">
                                {{#if atout.system.effet}}<div class="mb-5 color-light"><strong>Effet :</strong> <em>{{atout.system.effet}}</em></div>{{/if}}
                                {{{atout.system.description}}}
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="tab inventory" data-tab="inventory" style="display:none;">
        <div class="history-row">
            <div class="history-col">
                <div class="item-section">
                    <div class="item-header">
                        <h3 class="item-title"><i class="fas fa-khanda"></i> Armes</h3>
                        <div class="item-controls"><a class="item-control" data-action="createItem" data-type="arme"><i class="fas fa-plus"></i></a></div>
                    </div>
                    <div class="item-list">
                        {{#each armes as |arme id|}}
                        <div class="item" data-item-id="{{arme._id}}">
                            <div class="item-entry">
                                <div class="item-name-col">
                                    <img class="item-image cursor-pointer" data-action="rollWeapon" src="{{arme.img}}" title="Attaquer"/>
                                    <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{arme.name}}</h4>
                                </div>
                                <div class="item-details-col">DG: {{arme.system.degats_fixe}}</div>
                                <div class="item-controls">
                                    <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                                    <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                                </div>
                            </div>
                            <div class="item-summary mt-5">
                                <div class="font-09 text-muted mb-5">Type: {{#if (eq arme.system.type_arme "melee")}}Mêlée{{else}}Distance{{/if}} | Prise: {{arme.system.mains}} main(s)</div>
                                {{#if arme.system.special}}<div class="color-gold mb-5"><strong>Spécial:</strong> {{arme.system.special}}</div>{{/if}}
                                {{{arme.system.description}}}
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </div>
            </div>

            <div class="history-col">
                <div class="item-section">
                    <div class="item-header green">
                        <h3 class="item-title"><i class="fas fa-shield-alt"></i> Armures</h3>
                        <div class="item-controls"><a class="item-control" data-action="createItem" data-type="armure"><i class="fas fa-plus"></i></a></div>
                    </div>
                    <div class="item-list">
                        {{#each armures as |armure id|}}
                        <div class="item" data-item-id="{{armure._id}}">
                            <div class="item-entry">
                                <div class="item-name-col">
                                    <img src="{{armure.img}}" class="item-image"/>
                                    <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{armure.name}}</h4>
                                </div>
                                <div class="item-details-col flex-row gap-10 align-center justify-center">
                                    <label class="cursor-pointer"><input type="checkbox" data-action="toggleEquip" data-item-id="{{armure._id}}" {{checked armure.system.equipe}}/> <i class="fas fa-tshirt"></i></label>
                                    <span>Prot: {{armure.system.protection}}</span>
                                </div>
                                <div class="item-controls">
                                    <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                                    <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                                </div>
                            </div>
                            <div class="item-summary mt-5">
                                <div class="font-09 text-danger mb-5">
                                    {{#if armure.system.malus_init}}Malus Init: {{armure.system.malus_init}}{{/if}}
                                    {{#if armure.system.malus_mou}} | Malus Mouv: {{armure.system.malus_mou}}%{{/if}}
                                </div>
                                {{{armure.system.description}}}
                            </div>
                        </div>
                        {{/each}}
                    </div>
                </div>
            </div>
        </div>

        <div class="item-section">
            <div class="item-header grey">
                <h3 class="item-title">Équipement Divers</h3>
                <div class="item-controls"><a class="item-control" data-action="createItem" data-type="objet"><i class="fas fa-plus"></i> Ajouter</a></div>
            </div>
            <div class="item-list">
                {{#each objets as |objet id|}}
                <div class="item" data-item-id="{{objet._id}}">
                    <div class="item-entry">
                        <div class="item-name-col">
                            <img src="{{objet.img}}" class="item-image"/>
                            <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{objet.name}}</h4>
                        </div>
                        <div class="item-details-col">Qté: {{objet.system.quantite}}</div>
                        <div class="item-controls">
                            <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                            <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                        </div>
                    </div>
                    <div class="item-summary mt-5">
                        <div class="font-09 text-muted mb-5">Encombrement: {{objet.system.encombrement}} | Prix: {{objet.system.prix}}</div>
                        {{{objet.system.description}}}
                    </div>
                </div>
                {{/each}}
            </div>
        </div>
    </div>

    <div class="tab magic" data-tab="magic" style="display:none;">
        <div class="flex-row gap-20 align-stretch mb-15">
            <div class="item-section flex-1 m-0 border-blue">
                <h3 class="item-title colored-blue item-header-main">Capacité Magique</h3>
                <div class="flex-col gap-10">
                    <div>
                        <label class="font-bold text-muted">Caractéristique d'Incantation :</label>
                        <select name="system.stat_magie_defaut" class="w-100 mt-5">
                            {{#select system.stat_magie_defaut}}
                            <option value="cns">Connaissances</option>
                            <option value="vol">Volonté</option>
                            <option value="mag">Magie</option>
                            {{/select}}
                        </select>
                    </div>
                    <div class="flex-row justify-between mt-5" style="align-items: flex-start;">
                        <div class="flex-row gap-5" style="align-items: flex-start;">
                            <span class="magic-labels" style="padding-top: 2px;">Tours:</span>
                            <div style="display: grid; grid-template-columns: repeat(4, 16px); gap: 4px;">
                                {{#each toursBoxes}}<a class="spell-box {{#if this.checked}}tours{{else}}empty{{/if}}" data-action="spellUseClick" data-type="tours" data-value="{{this.value}}"></a>{{/each}}
                            </div>
                        </div>
                        <div class="flex-row gap-5" style="align-items: flex-start;">
                            <span class="magic-labels" style="padding-top: 2px;">Sorts:</span>
                            <div style="display: grid; grid-template-columns: repeat(4, 16px); gap: 4px;">
                                {{#each sortsBoxes}}<a class="spell-box {{#if this.checked}}sorts{{else}}empty{{/if}}" data-action="spellUseClick" data-type="sorts" data-value="{{this.value}}"></a>{{/each}}
                            </div>
                        </div>
                        <div class="flex-row gap-5" style="align-items: flex-start;">
                            <span class="magic-labels" style="padding-top: 2px;">Rituel:</span>
                            <div style="display: grid; grid-template-columns: repeat(4, 16px); gap: 4px;">
                                <a class="spell-box {{#if rituelBox.checked}}rituels{{else}}empty{{/if}}" data-action="spellUseClick" data-type="rituels" data-value="1"></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="item-section flex-1 m-0 border-purple">
                <div class="item-header purple mb-5">
                    <h3 class="item-title"><i class="fas fa-hat-wizard"></i> Domaines Magiques</h3>
                    <div class="item-controls"><a class="item-control" data-action="createItem" data-type="domaine"><i class="fas fa-plus"></i></a></div>
                </div>
                <div class="item-list">
                    {{#each domaines as |domaine id|}}
                    <div class="item" data-item-id="{{domaine._id}}">
                        <div class="item-entry no-border">
                            <div class="item-name-col">
                                <img class="item-image small" src="{{domaine.img}}"/>
                                <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{domaine.name}}</h4>
                            </div>
                            <div class="item-controls">
                                <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                                <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                            </div>
                        </div>
                        <div class="item-summary mt-5">
                            {{{domaine.system.description}}}
                        </div>
                    </div>
                    {{/each}}
                </div>
            </div>
        </div>

        <div class="flex-row gap-20 align-stretch">
            <div class="item-section flex-1 m-0">
                <div class="item-header blue mb-5">
                    <h3 class="item-title"><i class="fas fa-sparkles"></i> Tours de magie</h3>
                    <div class="item-controls"><a class="item-control" data-action="createItem" data-type="sort"><i class="fas fa-plus"></i></a></div>
                </div>
                <div class="item-list flex-col gap-5">
                    {{#each sorts as |sort id|}}
                    {{#if (eq sort.system.type_sort "tour")}}
                    <div class="item" data-item-id="{{sort._id}}">
                        <div class="item-entry">
                            <div class="item-name-col">
                                <img class="item-image cursor-pointer" data-action="rollSpell" src="{{sort.img}}" title="Incanter"/>
                                <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{sort.name}}</h4>
                            </div>
                            <div class="item-controls">
                                <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                                <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                            </div>
                        </div>
                        <div class="item-summary mt-5">
                            <div class="font-09 text-muted mb-5">Portée: {{sort.system.portee}} | Durée: {{sort.system.duree}} | Résistance: {{sort.system.resistance}}</div>
                            {{{sort.system.description}}}
                        </div>
                    </div>
                    {{/if}}
                    {{/each}}
                </div>
            </div>

            <div class="item-section flex-1 m-0">
                <div class="item-header blue mb-5">
                    <h3 class="item-title"><i class="fas fa-book-dead"></i> Sortilèges & Rituels</h3>
                    <div class="item-controls"><a class="item-control" data-action="createItem" data-type="sort"><i class="fas fa-plus"></i></a></div>
                </div>
                <div class="item-list flex-col gap-5">
                    {{#each sorts as |sort id|}}
                    {{#if (eq sort.system.type_sort "sortilege")}}
                    <div class="item" data-item-id="{{sort._id}}">
                        <div class="item-entry">
                            <div class="item-name-col">
                                <img class="item-image cursor-pointer" data-action="rollSpell" src="{{sort.img}}" title="Incanter"/>
                                <div class="flex-col">
                                    <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{sort.name}}</h4>
                                    <span class="text-highlight text-muted font-08" style="text-transform: uppercase;">{{sort.system.type_sort}} {{#if sort.system.domaine}}({{sort.system.domaine}}){{/if}}</span>
                                </div>
                            </div>
                            <div class="item-details-col">{{#if sort.system.difficulte}}Diff: {{sort.system.difficulte}}{{/if}}</div>
                            <div class="item-controls">
                                <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                                <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                            </div>
                        </div>
                        <div class="item-summary mt-5">
                            <div class="font-09 text-muted mb-5">Portée: {{sort.system.portee}} | Durée: {{sort.system.duree}} | Résistance: {{sort.system.resistance}}</div>
                            {{#if sort.system.formule}}<div class="mb-5 color-blue font-georgia" style="font-style:italic;">"{{sort.system.formule}}"</div>{{/if}}
                            {{#if sort.system.r_plus}}<div class="mb-5 color-gold"><strong>R+ :</strong> {{sort.system.r_plus}}</div>{{/if}}
                            {{{sort.system.description}}}
                        </div>
                    </div>
                    {{/if}}
                    {{#if (eq sort.system.type_sort "rituel")}}
                    <div class="item" data-item-id="{{sort._id}}">
                        <div class="item-entry">
                            <div class="item-name-col">
                                <img class="item-image cursor-pointer" data-action="rollSpell" src="{{sort.img}}" title="Incanter"/>
                                <div class="flex-col">
                                    <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{sort.name}}</h4>
                                    <span class="text-highlight text-muted font-08" style="text-transform: uppercase;">{{sort.system.type_sort}} {{#if sort.system.domaine}}({{sort.system.domaine}}){{/if}}</span>
                                </div>
                            </div>
                            <div class="item-details-col">{{#if sort.system.difficulte}}Diff: {{sort.system.difficulte}}{{/if}}</div>
                            <div class="item-controls">
                                <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                                <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                            </div>
                        </div>
                        <div class="item-summary mt-5">
                            <div class="font-09 text-muted mb-5">Portée: {{sort.system.portee}} | Durée: {{sort.system.duree}} | Résistance: {{sort.system.resistance}}</div>
                            {{#if sort.system.formule}}<div class="mb-5 color-blue font-georgia" style="font-style:italic;">"{{sort.system.formule}}"</div>{{/if}}
                            {{#if sort.system.r_plus}}<div class="mb-5 color-gold"><strong>R+ :</strong> {{sort.system.r_plus}}</div>{{/if}}
                            {{{sort.system.description}}}
                        </div>
                    </div>
                    {{/if}}
                    {{/each}}
                </div>
            </div>
        </div>

    <div class="tab biography" data-tab="biography" style="display:none;">
        <div class="history-row">
            <div class="history-col">
                <div class="item-section">
                    <h3 class="item-title colored-gold item-header-main mb-5 border-bottom-purple">Origine</h3>
                    {{#each origines as |origine|}}
                    <div class="item" data-item-id="{{origine._id}}">
                        <div class="item-entry no-border">
                            <img src="{{origine.img}}" class="item-image"/>
                            <h4 class="item-label cursor-pointer flex-1" data-action="toggleSummary">{{origine.name}}</h4>
                            <div class="item-controls">
                                <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                                <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                            </div>
                        </div>
                        <div class="item-summary mt-5">
                            <div class="font-09 text-muted mb-5">Bonus VIT: +{{origine.system.bonus_vit}} | Bonus SF: +{{origine.system.bonus_sf}} | Destin: {{origine.system.destin}}</div>
                            {{#if origine.system.talents_auto}}<div class="color-gold mb-5"><strong>Talents auto :</strong> {{origine.system.talents_auto}}</div>{{/if}}
                            {{#if origine.system.special}}<div class="mb-5"><strong>Spécial :</strong> {{origine.system.special}}</div>{{/if}}
                            {{#if origine.system.limitation}}<div class="text-danger mb-5"><strong>Limitation :</strong> {{origine.system.limitation}}</div>{{/if}}
                            {{{origine.system.description}}}
                        </div>
                    </div>
                    {{else}}<div class="empty-slot">Glissez une Origine ici</div>{{/each}}
                </div>
                <div class="item-section">
                    <h3 class="item-title colored-blue item-header-main mb-5 border-bottom-blue">Archétype</h3>
                    {{#each archetypes as |archetype|}}
                    <div class="item" data-item-id="{{archetype._id}}">
                        <div class="item-entry no-border">
                            <img src="{{archetype.img}}" class="item-image"/>
                            <h4 class="item-label cursor-pointer flex-1" data-action="toggleSummary">{{archetype.name}}</h4>
                            <div class="item-controls">
                                <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                                <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                            </div>
                        </div>
                        <div class="item-summary mt-5">
                            {{#if archetype.system.vices_vertus}}<div class="mb-5"><strong>Vices/Vertus :</strong> {{archetype.system.vices_vertus}}</div>{{/if}}
                            {{#if archetype.system.talents}}<div class="color-gold mb-5"><strong>Talents :</strong> {{archetype.system.talents}}</div>{{/if}}
                            {{{archetype.system.description}}}
                        </div>
                    </div>
                    {{else}}<div class="empty-slot">Glissez un Archétype ici</div>{{/each}}
                </div>
            </div>
            <div class="history-col">
                <div class="item-section history-col-h100">
                    <div class="flex-row justify-between item-header-main mb-5">
                        <h3 class="item-title colored-green">Carrière Active</h3>
                        {{#if carrieres.length}}
                        <a class="item-control color-gold font-09 cursor-pointer" data-action="archiveCareer" title="Archiver la carrière"><i class="fas fa-history"></i> Archiver</a>
                        {{/if}}
                    </div>
                    {{#each carrieres as |carriere|}}
                    <div class="item" data-item-id="{{carriere._id}}">
                        <div class="item-entry no-border">
                            <img src="{{carriere.img}}" class="item-image large"/>
                            <div class="flex-1 flex-col">
                                <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{carriere.name}}</h4>
                                <span class="text-muted">{{carriere.system.groupe}}</span>
                            </div>
                            <div class="item-controls">
                                <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                                <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                            </div>
                        </div>
                        <div class="item-summary mt-5">
                            {{#if carriere.system.specialites}}<div class="mb-5"><strong>Spécialités :</strong> {{carriere.system.specialites}}</div>{{/if}}
                            {{#if carriere.system.talents}}<div class="color-gold mb-5"><strong>Talents :</strong> {{carriere.system.talents}}</div>{{/if}}
                            {{#if carriere.system.equipement}}<div class="mb-5"><strong>Équipement :</strong> {{carriere.system.equipement}}</div>{{/if}}
                            {{{carriere.system.description}}}
                        </div>
                    </div>
                    {{else}}<div class="empty-slot">Glissez une Carrière ici</div>{{/each}}
                    <div class="mt-15">
                        <label class="font-bold text-muted">Anciennes Carrières</label>
                        <input type="text" name="system.carrieres_historiques" value="{{system.carrieres_historiques}}" class="w-100 mt-5"/>
                    </div>
                </div>
            </div>
        </div>
        <h3 class="comp-header">Biographie Complète</h3>
        <div class="editor-container">
            {{editor system.biographie target="system.biographie" button=true owner=owner editable=editable}}
        </div>
    </div>
</section>