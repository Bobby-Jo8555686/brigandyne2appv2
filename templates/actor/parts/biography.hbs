<div class="tab biography" data-tab="biography" style="display:none;">
    <div class="history-row">
        <div class="history-col">
            <div class="item-section">
                <h3 class="item-title colored-gold item-header-main mb-5 border-bottom-purple">Origine</h3>
                {{#each origines as |origine|}}
                <div class="item" data-item-id="{{origine._id}}">
                    <div class="item-entry no-border">
                        <img src="{{origine.img}}" class="item-image"/>
                        <h4 class="item-label cursor-pointer flex-1" data-action="toggleSummary">{{origine.name}}</h4>
                        <div class="item-controls">
                            <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                            <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                        </div>
                    </div>
                    <div class="item-summary mt-5">
                        <div class="font-09 text-muted mb-5">Bonus VIT: +{{origine.system.bonus_vit}} | Bonus SF: +{{origine.system.bonus_sf}} | Destin: {{origine.system.destin}}</div>
                        {{#if origine.system.talents_auto}}<div class="color-gold mb-5"><strong>Talents auto :</strong> {{origine.system.talents_auto}}</div>{{/if}}
                        {{#if origine.system.special}}<div class="mb-5"><strong>Spécial :</strong> {{origine.system.special}}</div>{{/if}}
                        {{#if origine.system.limitation}}<div class="text-danger mb-5"><strong>Limitation :</strong> {{origine.system.limitation}}</div>{{/if}}
                        {{{origine.system.description}}}
                    </div>
                </div>
                {{else}}<div class="empty-slot">Glissez une Origine ici</div>{{/each}}
            </div>
            <div class="item-section">
                <h3 class="item-title colored-blue item-header-main mb-5 border-bottom-blue">Archétype</h3>
                {{#each archetypes as |archetype|}}
                <div class="item" data-item-id="{{archetype._id}}">
                    <div class="item-entry no-border">
                        <img src="{{archetype.img}}" class="item-image"/>
                        <h4 class="item-label cursor-pointer flex-1" data-action="toggleSummary">{{archetype.name}}</h4>
                        <div class="item-controls">
                            <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                            <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                        </div>
                    </div>
                    <div class="item-summary mt-5">
                        {{#if archetype.system.vices_vertus}}<div class="mb-5"><strong>Vices/Vertus :</strong> {{archetype.system.vices_vertus}}</div>{{/if}}
                        {{#if archetype.system.talents}}<div class="color-gold mb-5"><strong>Talents :</strong> {{archetype.system.talents}}</div>{{/if}}
                        {{{archetype.system.description}}}
                    </div>
                </div>
                {{else}}<div class="empty-slot">Glissez un Archétype ici</div>{{/each}}
            </div>
        </div>
        <div class="history-col">
            <div class="item-section history-col-h100">
                <div class="flex-row justify-between item-header-main mb-5">
                    <h3 class="item-title colored-green">Carrière Active</h3>
                    {{#if carrieres.length}}
                    <a class="item-control color-gold font-09 cursor-pointer" data-action="archiveCareer" title="Archiver la carrière"><i class="fas fa-history"></i> Archiver</a>
                    {{/if}}
                </div>
                {{#each carrieres as |carriere|}}
                <div class="item" data-item-id="{{carriere._id}}">
                    <div class="item-entry no-border">
                        <img src="{{carriere.img}}" class="item-image large"/>
                        <div class="flex-1 flex-col">
                            <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{carriere.name}}</h4>
                            <span class="text-muted">{{carriere.system.groupe}}</span>
                        </div>
                        <div class="item-controls">
                            <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                            <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                        </div>
                    </div>
                    <div class="item-summary mt-5">
                        {{#if carriere.system.specialites}}<div class="mb-5"><strong>Spécialités :</strong> {{carriere.system.specialites}}</div>{{/if}}
                        {{#if carriere.system.talents}}<div class="color-gold mb-5"><strong>Talents :</strong> {{carriere.system.talents}}</div>{{/if}}
                        {{#if carriere.system.equipement}}<div class="mb-5"><strong>Équipement :</strong> {{carriere.system.equipement}}</div>{{/if}}
                        {{{carriere.system.description}}}
                    </div>
                </div>
                {{else}}<div class="empty-slot">Glissez une Carrière ici</div>{{/each}}
                <div class="mt-15">
                    <label class="font-bold text-muted">Anciennes Carrières</label>
                    <input type="text" name="system.carrieres_historiques" value="{{system.carrieres_historiques}}" class="w-100 mt-5"/>
                </div>
            </div>
        </div>
    </div>
    <div class="item-section mb-15">
    <div class="item-header gold mb-5">
        <h3 class="item-title"><i class="fas fa-balance-scale"></i> Vices & Vertus</h3>
    </div>
    
    {{#if archetypeVicesText}}
    <div class="font-09 text-muted mb-10" style="padding: 10px; background: rgba(212, 175, 55, 0.1); border-left: 3px solid #d4af37; font-family: 'Georgia', serif;">
        <strong>Personnalité de l'Archétype :</strong> <em>{{archetypeVicesText}}</em>
    </div>
    {{/if}}

    <div class="vices-container" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px;">
        {{#each vicesVertus}}
        <div style="display: flex; justify-content: space-between; align-items: center; background: rgba(0,0,0,0.1); padding: 5px 10px; border-radius: 5px; border: 1px solid #333;">
            
            <div style="flex: 1; text-align: right; {{#if isViceActive}}color: #b71c1c; font-weight: bold;{{/if}}">
                {{vice}} <span style="background: rgba(0,0,0,0.3); padding: 2px 5px; border-radius: 3px; color: white;">{{viceVal}}</span>
            </div>
            
            <div style="margin: 0 10px; display: flex; gap: 5px;">
                <a style="cursor:pointer;" data-action="adjustVice" data-key="{{key}}" data-delta="1" title="Pencher vers le Vice"><i class="fas fa-plus-circle" style="color:#b71c1c;"></i></a>
                <a style="cursor:pointer;" data-action="adjustVice" data-key="{{key}}" data-delta="-1" title="Pencher vers la Vertu"><i class="fas fa-plus-circle" style="color:#4CAF50;"></i></a>
            </div>
            
            <div style="flex: 1; text-align: left; {{#if isVertuActive}}color: #4CAF50; font-weight: bold;{{/if}}">
                <span style="background: rgba(0,0,0,0.3); padding: 2px 5px; border-radius: 3px; color: white;">{{vertuVal}}</span> {{vertu}}
            </div>

        </div>
        {{/each}}
    </div>

    <h3 class="comp-header">Biographie Complète</h3>
    <div class="editor-container">
        <prose-mirror name="system.biography" toggled="true" value="{{system.biography}}" document-uuid="{{actor.uuid}}">
            {{{enrichedBiography}}}
        </prose-mirror>
    </div>
</div>
