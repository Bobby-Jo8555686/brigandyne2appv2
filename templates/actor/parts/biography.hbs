<div class="history-row">
    <div class="history-col">
        <div class="item-section mb-15">
            <div class="section-header" style="border-top-color: #8e44ad;">
                <i class="fas fa-scroll"></i> Origine
            </div>
            {{#each origines as |origine|}}
            <div class="item mt-5" data-item-id="{{origine._id}}">
                <div class="item-entry-card">
                    <div class="flex-row align-center gap-10 flex-2">
                        <img src="{{origine.img}}" class="item-icon"/>
                        <h4 class="item-label cursor-pointer m-0 flex-1" data-action="toggleSummary">{{origine.name}}</h4>
                    </div>
                    <div class="item-controls flex-row gap-5 justify-end">
                        <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                        <a class="delete-btn" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                    </div>
                </div>
                <div class="item-summary mt-5">
                    <div class="font-09 text-muted mb-5">Bonus VIT: +{{origine.system.bonus_vit}} | Bonus SF: +{{origine.system.bonus_sf}} | Destin: {{origine.system.destin}}</div>
                    {{#if origine.system.talents_auto}}<div class="color-gold mb-5"><strong>Talents auto :</strong> {{origine.system.talents_auto}}</div>{{/if}}
                    {{#if origine.system.special}}<div class="mb-5"><strong>Spécial :</strong> {{origine.system.special}}</div>{{/if}}
                    {{#if origine.system.limitation}}<div class="text-danger mb-5"><strong>Limitation :</strong> {{origine.system.limitation}}</div>{{/if}}
                    {{{origine.system.description}}}
                </div>
            </div>
            {{else}}<div class="empty-list mt-5">Glissez une Origine ici</div>{{/each}}
        </div>

        <div class="item-section mb-15">
            <div class="section-header" style="border-top-color: #85c1e9;">
                <i class="fas fa-chess-knight"></i> Archétype
            </div>
            {{#each archetypes as |archetype|}}
            <div class="item mt-5" data-item-id="{{archetype._id}}">
                <div class="item-entry-card">
                    <div class="flex-row align-center gap-10 flex-2">
                        <img src="{{archetype.img}}" class="item-icon"/>
                        <h4 class="item-label cursor-pointer m-0 flex-1" data-action="toggleSummary">{{archetype.name}}</h4>
                    </div>
                    <div class="item-controls flex-row gap-5 justify-end">
                        <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                        <a class="delete-btn" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                    </div>
                </div>
                <div class="item-summary mt-5">
                    {{#if archetype.system.vices_vertus}}<div class="mb-5"><strong>Vices/Vertus :</strong> {{archetype.system.vices_vertus}}</div>{{/if}}
                    {{#if archetype.system.talents}}<div class="color-gold mb-5"><strong>Talents :</strong> {{archetype.system.talents}}</div>{{/if}}
                    {{{archetype.system.description}}}
                </div>
            </div>
            {{else}}<div class="empty-list mt-5">Glissez un Archétype ici</div>{{/each}}
        </div>
    </div>

    <div class="history-col">
        <div class="item-section history-col-h100 mb-15">
            <div class="section-header" style="border-top-color: #4CAF50;">
                <i class="fas fa-briefcase"></i> Carrière Active
                {{#if carrieres.length}}
                <div class="flex-1 text-right"><a class="item-control color-gold font-08 cursor-pointer" data-action="archiveCareer" title="Archiver la carrière"><i class="fas fa-history"></i> Archiver</a></div>
                {{/if}}
            </div>
            {{#each carrieres as |carriere|}}
            <div class="item mt-5" data-item-id="{{carriere._id}}">
                <div class="item-entry-card">
                    <div class="flex-row align-center gap-10 flex-2">
                        <img src="{{carriere.img}}" class="item-icon"/>
                        <div class="flex-1 flex-col">
                            <h4 class="item-label cursor-pointer m-0" data-action="toggleSummary">{{carriere.name}}</h4>
                            <span class="text-muted font-08">{{carriere.system.groupe}}</span>
                        </div>
                    </div>
                    <div class="item-controls flex-row gap-5 justify-end">
                        <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                        <a class="delete-btn" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                    </div>
                </div>
                <div class="item-summary mt-5">
                    {{#if carriere.system.specialites}}<div class="mb-5"><strong>Spécialités :</strong> {{carriere.system.specialites}}</div>{{/if}}
                    {{#if carriere.system.talents}}<div class="color-gold mb-5"><strong>Talents :</strong> {{carriere.system.talents}}</div>{{/if}}
                    {{#if carriere.system.equipement}}<div class="mb-5"><strong>Équipement :</strong> {{carriere.system.equipement}}</div>{{/if}}
                    {{{carriere.system.description}}}
                </div>
            </div>
            {{else}}<div class="empty-list mt-5">Glissez une Carrière ici</div>{{/each}}

            <div class="mt-15">
                <label class="font-bold text-muted">Anciennes Carrières</label>
                <input type="text" name="system.carrieres_historiques" value="{{system.carrieres_historiques}}" class="w-100 mt-5"/>
            </div>
        </div>
    </div>
</div>

<div class="item-section mb-15">
    <div class="section-header" style="border-top-color: #d4af37;">
        <i class="fas fa-balance-scale"></i> Vices & Vertus
    </div>
    
    {{#if archetypeVicesText}}
    <div class="box-gold mt-10 mb-10 font-09 text-muted">
        <strong>Personnalité de l'Archétype :</strong> <em>{{archetypeVicesText}}</em>
    </div>
    {{/if}}

    <div class="vices-grid mt-10">
        {{#each vicesVertus}}
        <div class="vice-vertu-row">
            <div class="flex-1 text-right {{#if isViceActive}}text-vice{{/if}}">
                {{vice}} <span class="value-badge">{{viceVal}}</span>
            </div>
            <div class="flex-row gap-5 px-5 mx-10">
                <a class="vice-btn" data-action="adjustVice" data-key="{{key}}" data-delta="1" title="Pencher vers le Vice"><i class="fas fa-plus-circle" style="color:#ff5252;"></i></a>
                <a class="vice-btn" data-action="adjustVice" data-key="{{key}}" data-delta="-1" title="Pencher vers la Vertu"><i class="fas fa-plus-circle" style="color:#4CAF50;"></i></a>
            </div>
            <div class="flex-1 text-left {{#if isVertuActive}}text-vertu{{/if}}">
                <span class="value-badge">{{vertuVal}}</span> {{vertu}}
            </div>
        </div>
        {{/each}}
    </div>

    <div class="section-header mt-15" style="border-top-color: #8b0000;">
        <i class="fas fa-book"></i> Biographie Complète
    </div>
    <div class="editor-container mt-10">
        <prose-mirror name="system.biography" toggled="true" value="{{system.biography}}" document-uuid="{{actor.uuid}}">
            {{{enrichedBiography}}}
        </prose-mirror>
    </div>
</div>