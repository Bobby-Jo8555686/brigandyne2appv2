<header class="sheet-header-actor">
    <img class="actor-profile-img cursor-pointer" src="{{actor.img}}" data-action="editImage" data-edit="img" title="{{actor.name}}"/>
    
    <div class="header-bio">
        <div class="bio-line">
            <label class="bio-label">Nom, surnom</label>
            <input class="bio-input charname" name="name" type="text" value="{{actor.name}}"/>
        </div>
        
        {{#if (eq actor.type "personnage")}}
        <div class="bio-line">
            <label class="bio-label">Peuple, sang</label>
            <input class="bio-input-readonly" type="text" value="{{#each origines}}{{name}}{{/each}}" readonly/>
        </div>
        <div class="bio-line">
            <label class="bio-label">Archétype</label>
            <input class="bio-input-readonly" type="text" value="{{#each archetypes}}{{name}}{{/each}}" readonly/>
        </div>
        <div class="bio-line">
            <label class="bio-label">Carrière(s)</label>
            <input class="bio-input-readonly" type="text" value="{{#each carrieres}}{{name}} {{/each}}" readonly/>
        </div>

        <div class="header-resources">
            <div class="resource-box vit">
                <label>VIT:</label>
                <input type="number" name="system.vitalite.value" value="{{system.vitalite.value}}"/>
                <span>/ {{system.vitalite.max}}</span>
            </div>
            <div class="resource-box sf">
                <label>SF:</label>
                <input type="number" name="system.sangfroid.value" value="{{system.sangfroid.value}}"/>
                <span>/ {{system.sangfroid.max}}</span>
            </div>
            <div class="resource-box des">
                <label>DES:</label>
                <input type="number" name="system.destin.value" value="{{system.destin.value}}"/>
                <span>/ {{system.destin.max}}</span>
            </div>
            <div class="resource-box px">
                <label class="cursor-pointer" data-action="spendXp" title="Dépenser de l'Expérience">PX:</label>
                <input type="number" name="system.experience.value" value="{{system.experience.value}}"/>
            </div>
        </div>
        {{else}}
        <div class="bio-line">
            <label class="bio-label">Type de PNJ</label>
            <select class="bio-input" name="system.type_pnj">
                {{selectOptions pnjTypes selected=system.type_pnj blank="- Choisissez -"}}
            </select>
        </div>
        <div class="header-resources">
            <div class="resource-box vit">
                <label>VIT:</label>
                <input type="number" name="system.vitalite.value" value="{{system.vitalite.value}}"/>
                <span>/ {{system.vitalite.max}}</span>
            </div>
            <div class="resource-box sf">
                <label>SF:</label>
                <input type="number" name="system.sangfroid.value" value="{{system.sangfroid.value}}"/>
                <span>/ {{system.sangfroid.max}}</span>
            </div>
        </div>
        {{/if}}
    </div>

    <div class="header-stats">
        <div class="combat-box init">
            <label class="roll-init" data-action="rollInit" title="Lancer l'Initiative">Initiative</label>
            <span>{{system.initiative.value}}</span>
        </div>
        <div class="combat-box prot">
            <label>Protection</label>
            <span>{{system.protection.value}}</span>
        </div>
        <div class="malus-armure">
            <label class="handicap-label justify-center">
                <input type="checkbox" name="system.options.malus_armure" {{checked system.options.malus_armure}}/>
                Malus d'armures
            </label>
        </div>
    </div>
</header>