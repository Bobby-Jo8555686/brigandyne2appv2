<div class="stats-container">
    
    <div class="competences-col flex-1">
        <div class="comp-header">
            <div class="flex-2">Compétences</div>
            <div class="stat-base" title="Base">Bs.</div>
            <div class="stat-prog" title="Progression">Prog.</div>
            <div class="stat-actual" title="Actuel">Act.</div>
        </div>
        <div class="item-list">
            {{#each system.stats as |stat key|}}
            <div class="stat-row">
                <label class="stat-label cursor-pointer" data-action="rollStat" data-key="{{key}}">{{stat.label}}</label>
                <div class="stat-base"><input type="number" name="system.stats.{{key}}.value" value="{{stat.value}}"/></div>
                <div class="stat-prog flex-row justify-center gap-3 pt-4">
                    {{#each stat.progressBoxes}}
                    <a class="prog-box {{#if checked}}checked{{/if}} {{#if locked}}locked{{/if}}" data-action="progressClick" data-stat="{{statKey}}" data-value="{{value}}" title="{{#if locked}}Hors Profil{{else}}Niveau {{value}}{{/if}}"></a>
                    {{/each}}
                </div>
                <div class="stat-actual"><div class="actual-box">{{stat.total}}</div></div>
            </div>
            {{/each}}
        </div>

        <div class="handicaps-box mt-15">
            <h3 class="handicaps-title"><i class="fas fa-skull-crossbones"></i> États & Handicaps</h3>
            <div class="handicaps-grid">
                <label class="handicap-label"><input type="checkbox" name="system.handicaps.affaibli" {{checked system.handicaps.affaibli}}/> Affaibli (-10)</label>
                <label class="handicap-label"><input type="checkbox" name="system.handicaps.affame" {{checked system.handicaps.affame}}/> Affamé (-1 DG)</label>
                <label class="handicap-label"><input type="checkbox" name="system.handicaps.apeure" {{checked system.handicaps.apeure}}/> Apeuré</label>
                <label class="handicap-label"><input type="checkbox" name="system.handicaps.aveugle" {{checked system.handicaps.aveugle}}/> Aveuglé (0)</label>
                <label class="handicap-label"><input type="checkbox" name="system.handicaps.confus" {{checked system.handicaps.confus}}/> Confus</label>
                <label class="handicap-label"><input type="checkbox" name="system.handicaps.demoralise" {{checked system.handicaps.demoralise}}/> Démoralisé</label>
                <label class="handicap-label"><input type="checkbox" name="system.handicaps.ensanglante" {{checked system.handicaps.ensanglante}}/> Ensanglanté</label>
                <label class="handicap-label"><input type="checkbox" name="system.handicaps.essouffle" {{checked system.handicaps.essouffle}}/> Essoufflé</label>
                <label class="handicap-label"><input type="checkbox" name="system.handicaps.paralyse" {{checked system.handicaps.paralyse}}/> Paralysé</label>
                <label class="handicap-label"><input type="checkbox" name="system.handicaps.ralenti" {{checked system.handicaps.ralenti}}/> Ralenti</label>
                <label class="handicap-label"><input type="checkbox" name="system.handicaps.sonne" {{checked system.handicaps.sonne}}/> Sonné</label>
                <label class="handicap-label"><input type="checkbox" name="system.handicaps.terrorise" {{checked system.handicaps.terrorise}}/> Terrorisé</label>
            </div>
            <div class="text-center mt-10">
                <a class="btn-action" style="border-color: #ff5252; background: #8b0000;" data-action="ignoreHandicap"><i class="fas fa-fire-alt"></i> Ignorer (2 SF)</a>
            </div>
        </div>
    </div>

    <div class="right-col flex-1">
        
        <div class="item-section mb-15">
            <div class="section-header">
                <i class="fas fa-khanda"></i> Armes
            </div>
            <div class="item-list">
                {{#each armesEquipees as |arme id|}}
                <div class="item" data-item-id="{{arme._id}}">
                    <div class="item-entry-card">
                        <div class="flex-row align-center gap-10 flex-2">
                            <img class="item-icon cursor-pointer" data-action="rollWeapon" src="{{arme.img}}" title="Attaquer"/>
                            <div class="flex-row align-center gap-5">
                                <h4 class="item-label cursor-pointer m-0" data-action="toggleSummary">{{arme.name}}</h4>
                                {{#if arme.uses}}
                                <div class="flex-row align-center gap-3 font-08" style="background:rgba(0,0,0,0.5); padding:2px 5px; border-radius:3px; border:1px solid #555;">
                                    <input type="number" class="use-input" data-item-id="{{arme._id}}" data-act-id="{{arme.primaryActivityId}}" value="{{arme.uses.value}}" style="width:20px; height:16px; padding:0; text-align:center; background:transparent; border:none; color:#fff;" min="0" max="{{arme.uses.max}}">
                                    <span class="color-light">/ {{arme.uses.max}}</span>
                                </div>
                                {{/if}}
                            </div>
                        </div>
                        <div class="font-09 font-bold text-center flex-1">
                            DG: {{arme.system.degats_fixe}}
                        </div>
                        <div class="item-controls flex-row gap-5 justify-end">
                            <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                        </div>
                    </div>
                    <div class="item-summary">
                        <div class="font-09 text-muted mb-5">Type: {{#if (eq arme.system.type_arme "melee")}}Mêlée{{else}}Distance{{/if}} | Prise: {{arme.system.mains}} main(s)</div>
                        {{{arme.system.description}}}
                    </div>
                </div>
                {{/each}}
            </div>
        </div>

        <div class="item-section mb-15">
            <div class="section-header" style="border-top-color: #d4af37;">
                <i class="fas fa-star" style="color: #d4af37;"></i> Spécialités & Talents
                <div class="flex-1 text-right"><a class="item-control" data-action="createItem" data-type="atout" style="font-size: 0.8em;"><i class="fas fa-plus"></i></a></div>
            </div>
            <div class="item-list">
                {{#each atouts as |atout id|}}
                <div class="item" data-item-id="{{atout._id}}">
                    <div class="item-entry-card">
                        <div class="flex-row align-center gap-10 flex-2">
                            <img class="item-icon cursor-pointer" data-action="rollItem" src="{{atout.img}}" title="Déclencher le talent"/>
                            <div class="flex-col align-stretch">
                                <div class="flex-row align-center gap-5">
                                    <h4 class="item-label cursor-pointer m-0" data-action="toggleSummary">{{atout.name}}</h4>
                                    {{#if atout.uses}}
                                    <div class="flex-row align-center gap-3 font-08" style="background:rgba(0,0,0,0.5); padding:2px 5px; border-radius:3px; border:1px solid #555;">
                                        <input type="number" class="use-input" data-item-id="{{atout._id}}" data-act-id="{{atout.primaryActivityId}}" value="{{atout.uses.value}}" style="width:20px; height:16px; padding:0; text-align:center; background:transparent; border:none; color:#fff;" min="0" max="{{atout.uses.max}}">
                                        <span class="color-light">/ {{atout.uses.max}}</span>
                                    </div>
                                    {{/if}}
                                </div>
                                <div class="text-muted mt-2 font-085">
                                    <strong>{{atout.system.type_atout}}</strong> {{#if atout.system.stat_liee}}({{atout.system.stat_liee}}){{/if}}
                                    {{#if atout.system.bonus}}<span class="text-highlight">+{{atout.system.bonus}}</span>{{/if}}
                                </div>
                            </div>
                        </div>
                        <div class="item-controls flex-row gap-5 justify-end">
                            <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                            <a class="item-control item-delete" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                        </div>
                    </div>
                    <div class="item-summary">
                        {{#if atout.system.effet}}<div class="mb-5 color-light"><strong>Effet :</strong> <em>{{atout.system.effet}}</em></div>{{/if}}
                        {{{atout.system.description}}}
                    </div>
                </div>
                {{/each}}
            </div>
        </div>

        <div class="item-section">
            <div class="section-header" style="border-top-color: #85c1e9;">
                <i class="fas fa-bolt" style="color: #85c1e9;"></i> Effets Actifs & États
            </div>
            
            {{#if effetsActifs.length}}
                <ul class="item-list">
                    {{#each effetsActifs}}
                    <li class="item-entry-card">
                        <div class="flex-row align-center gap-10 flex-1">
                            <img src="{{img}}" class="item-icon">
                            <div class="flex-col">
                                <div class="font-bold color-light font-095" style="text-transform: uppercase;">{{name}}</div>
                                <div class="text-muted font-08">{{description}}</div>
                            </div>
                        </div>
                        <a class="delete-btn" data-action="deleteEffect" data-id="{{id}}" title="Supprimer cet effet">
                            <i class="fas fa-trash"></i>
                        </a>
                    </li>
                    {{/each}}
                </ul>
            {{else}}
                <div class="empty-list">
                    Aucun effet en cours.
                </div>
            {{/if}}
        </div>

    </div>
</div>