<div class="tab details" data-tab="details" style="display:block;">
    <div class="item-grid">
        <div class="form-group-item">
            <label>Groupe de carrières</label>
            <input type="text" name="system.groupe" value="{{system.groupe}}"/>
        </div>
        <div class="form-group-item col">
            <label>Spécialités</label>
            <textarea name="system.specialites" rows="1">{{system.specialites}}</textarea>
        </div>
        <div class="form-group-item col">
            <label>Talents</label>
            <textarea name="system.talents" rows="1">{{system.talents}}</textarea>
        </div>
        <div class="form-group-item col">
            <label>Équipement</label>
            <textarea name="system.equipement" rows="1">{{system.equipement}}</textarea>
        </div>

        <div class="item-header grey mt-20">
            <h3 class="item-title">Profil de Progression (Max)</h3>
        </div>
        <div class="stats-modifiers-grid">
            {{#each system.stats as |mod key|}}
            <div class="stat-mod">
                <label>{{key}}</label>
                <input type="number" name="system.stats.{{key}}" value="{{mod}}" min="0" max="6"/>
            </div>
            {{/each}}
        </div>
    </div>
</div>