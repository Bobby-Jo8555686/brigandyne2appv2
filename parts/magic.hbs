<div class="flex-row gap-20 align-stretch mb-15">
    <div class="item-section flex-1 m-0 border-blue">
        <h3 class="item-title colored-blue item-header-main">Capacité Magique</h3>
        <div class="flex-col gap-10">
            <div>
                <label class="font-bold text-muted">Caractéristique d'Incantation :</label>
                <select name="system.stat_magie_defaut" class="w-100 mt-5">
                    {{selectOptions choixStatMagie selected=system.stat_magie_defaut}}
                </select>
            </div>
            <div style="text-align: right; margin-bottom: 10px; padding-right: 5px;">
                <button type="button" data-action="resetMagic" title="Remettre à zéro les compteurs de magie après 8h de repos" style="background: #4a6491; color: white; border: 1px solid #333; padding: 5px 10px; border-radius: 5px; cursor: pointer; font-family: 'Georgia', serif;">
                    <i class="fas fa-bed"></i> Repos du Mage
                </button>
            </div>
            <div class="flex-row justify-between mt-5" style="align-items: flex-start;">
                <div class="flex-row gap-5" style="align-items: flex-start;">
                    <span class="magic-labels" style="padding-top: 2px;">Tours:</span>
                    <div style="display: grid; grid-template-columns: repeat(4, 16px); gap: 4px;">
                        {{#each toursBoxes}}<a class="spell-box {{#if this.checked}}tours{{else}}empty{{/if}}" data-action="spellUseClick" data-type="tours" data-value="{{this.value}}"></a>{{/each}}
                    </div>
                </div>
                <div class="flex-row gap-5" style="align-items: flex-start;">
                    <span class="magic-labels" style="padding-top: 2px;">Sorts:</span>
                    <div style="display: grid; grid-template-columns: repeat(4, 16px); gap: 4px;">
                        {{#each sortsBoxes}}<a class="spell-box {{#if this.checked}}sorts{{else}}empty{{/if}}" data-action="spellUseClick" data-type="sorts" data-value="{{this.value}}"></a>{{/each}}
                    </div>
                </div>
                <div class="flex-row gap-5" style="align-items: flex-start;">
                    <span class="magic-labels" style="padding-top: 2px;">Rituel:</span>
                    <div style="display: grid; grid-template-columns: repeat(4, 16px); gap: 4px;">
                        <a class="spell-box {{#if rituelBox.checked}}rituels{{else}}empty{{/if}}" data-action="spellUseClick" data-type="rituels" data-value="1"></a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="item-section flex-1 m-0 border-purple">
        <div class="item-header purple mb-5">
            <h3 class="item-title"><i class="fas fa-hat-wizard"></i> Domaines Magiques</h3>
            <div class="item-controls"><a class="item-control" data-action="createItem" data-type="domaine"><i class="fas fa-plus"></i></a></div>
        </div>
        <div class="item-list">
            {{#each domaines as |domaine id|}}
            <div class="item" data-item-id="{{domaine._id}}">
                <div class="item-entry no-border">
                    <div class="item-name-col">
                        <img class="item-image small" src="{{domaine.img}}"/>
                        <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{domaine.name}}</h4>
                    </div>
                    <div class="item-controls">
                        <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                        <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                    </div>
                </div>
                <div class="item-summary mt-5">
                    {{{domaine.system.description}}}
                </div>
            </div>
            {{/each}}
        </div>
    </div>
</div>

<div class="flex-row gap-20 align-stretch">
    <div class="item-section flex-1 m-0">
        <div class="item-header blue mb-5">
            <h3 class="item-title"><i class="fas fa-sparkles"></i> Tours de magie</h3>
            <div class="item-controls"><a class="item-control" data-action="createItem" data-type="sort"><i class="fas fa-plus"></i></a></div>
        </div>
        <div class="item-list flex-col gap-5">
            {{#each sorts as |sort id|}}
            {{#if (eq sort.system.type_sort "tour")}}
            <div class="item" data-item-id="{{sort._id}}">
                <div class="item-entry">
                    <div class="item-name-col">
                        <img class="item-image cursor-pointer" data-action="rollSpell" src="{{sort.img}}" title="Incanter"/>
                        <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{sort.name}}</h4>
                    </div>
                    <div class="item-controls">
                        <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                        <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                    </div>
                </div>
                <div class="item-summary mt-5">
                    <div class="font-09 text-muted mb-5">Portée: {{sort.system.portee}} | Durée: {{sort.system.duree}} | Résistance: {{sort.system.resistance}}</div>
                    {{{sort.system.description}}}
                </div>
            </div>
            {{/if}}
            {{/each}}
        </div>
    </div>

    <div class="item-section flex-1 m-0">
        <div class="item-header blue mb-5">
            <h3 class="item-title"><i class="fas fa-book-dead"></i> Sortilèges & Rituels</h3>
            <div class="item-controls"><a class="item-control" data-action="createItem" data-type="sort"><i class="fas fa-plus"></i></a></div>
        </div>
        <div class="item-list flex-col gap-5">
            {{#each sorts as |sort id|}}
            
            {{#if (eq sort.system.type_sort "sortilege")}}
            <div class="item" data-item-id="{{sort._id}}">
                <div class="item-entry">
                    <div class="item-name-col">
                        <img class="item-image cursor-pointer" data-action="rollSpell" src="{{sort.img}}" title="Incanter"/>
                        <div class="flex-col">
                            <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{sort.name}}</h4>
                            <span class="text-highlight text-muted font-08" style="text-transform: uppercase;">{{sort.system.type_sort}} {{#if sort.system.domaine}}({{sort.system.domaine}}){{/if}}</span>
                        </div>
                    </div>
                    <div class="item-details-col">{{#if sort.system.difficulte}}Diff: {{sort.system.difficulte}}{{/if}}</div>
                    <div class="item-controls">
                        <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                        <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                    </div>
                </div>
                <div class="item-summary mt-5">
                    <div class="font-09 text-muted mb-5">Portée: {{sort.system.portee}} | Durée: {{sort.system.duree}} | Résistance: {{sort.system.resistance}}</div>
                    {{#if sort.system.formule}}<div class="mb-5 color-blue font-georgia" style="font-style:italic;">"{{sort.system.formule}}"</div>{{/if}}
                    {{#if sort.system.r_plus}}<div class="mb-5 color-gold"><strong>R+ :</strong> {{sort.system.r_plus}}</div>{{/if}}
                    {{{sort.system.description}}}
                </div>
            </div>
            {{/if}}
            
            {{#if (eq sort.system.type_sort "rituel")}}
            <div class="item" data-item-id="{{sort._id}}">
                <div class="item-entry">
                    <div class="item-name-col">
                        <img class="item-image cursor-pointer" data-action="rollSpell" src="{{sort.img}}" title="Incanter"/>
                        <div class="flex-col">
                            <h4 class="item-label cursor-pointer" data-action="toggleSummary">{{sort.name}}</h4>
                            <span class="text-highlight text-muted font-08" style="text-transform: uppercase;">{{sort.system.type_sort}} {{#if sort.system.domaine}}({{sort.system.domaine}}){{/if}}</span>
                        </div>
                    </div>
                    <div class="item-details-col">{{#if sort.system.difficulte}}Diff: {{sort.system.difficulte}}{{/if}}</div>
                    <div class="item-controls">
                        <a class="item-control" data-action="editItem"><i class="fas fa-edit"></i></a>
                        <a class="item-control" data-action="deleteItem"><i class="fas fa-trash"></i></a>
                    </div>
                </div>
                <div class="item-summary mt-5">
                    <div class="font-09 text-muted mb-5">Portée: {{sort.system.portee}} | Durée: {{sort.system.duree}} | Résistance: {{sort.system.resistance}}</div>
                    {{#if sort.system.formule}}<div class="mb-5 color-blue font-georgia" style="font-style:italic;">"{{sort.system.formule}}"</div>{{/if}}
                    {{#if sort.system.r_plus}}<div class="mb-5 color-gold"><strong>R+ :</strong> {{sort.system.r_plus}}</div>{{/if}}
                    {{{sort.system.description}}}
                </div>
            </div>
            {{/if}}
            
            {{/each}}
        </div>
    </div>
</div>